{
  "name": "prepai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui --project=ui",
    "test:server": "playwright test --project=server",
    "test:chromium": "playwright test --project=ui-chromium --project=server-chromium",
    "report": "playwright show-report",
    "piston:start": "pnpm --filter server exec tsx ../types/piston.ts start",
    "piston:stop": "pnpm --filter server exec tsx ../types/piston.ts stop",
    "piston:setup": "pnpm --filter server exec tsx ../types/piston.ts setup",
    "piston:status": "pnpm --filter server exec tsx ../types/piston.ts status"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "@types/node": "22.15.3",
    "typescript": "5.8.3"
  }
}
